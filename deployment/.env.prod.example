# ============================================================
# .env.prod — Variables de entorno para producción
# COPIA este archivo como .env.prod y completa los valores
# NUNCA subas .env.prod a Git (ya está en .gitignore)
# ============================================================

# ── Dominio ──────────────────────────────────────────────────
DOMAIN=mymemo.duckdns.org          # Tu subdominio DuckDNS
EMAIL=tu@email.com                 # Email para Let's Encrypt

# ── Base de datos ─────────────────────────────────────────────
DB_USER=lifelogs_user
DB_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO
DB_NAME=lifelogs_db

# ── Seguridad ─────────────────────────────────────────────────
# Genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERA_UN_SECRET_KEY_ALEATORIO_AQUI

# ── AWS S3 ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=tu_access_key_id
AWS_SECRET_ACCESS_KEY=tu_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_IMAGES=mymemo-images-prod-2026
S3_BUCKET_THUMBNAILS=mymemo-thumbnails-prod-2026

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...tu_api_key
